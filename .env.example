# Public beta label shown in the UI. This is safe to expose to the browser.
NEXT_PUBLIC_BETA_VERSION="Beta v0.1.4"

# Optional server-side event forwarder.
# Keep these values only in Vercel Project Settings > Environment Variables.
# Do not prefix secrets with NEXT_PUBLIC_.
BETA_EVENT_WEBHOOK_URL=""
BETA_EVENT_WEBHOOK_TOKEN=""

# Admin dashboard protection.
# Set these only in local .env.local or Vercel Environment Variables.
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""

# Optional live beta data storage for /admin.
# Use Supabase Project Settings > API values.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BETA_EVENTS_TABLE="beta_events"
